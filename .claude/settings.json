{
  "permissions": {
    "defaultMode": "default",

    "allow": [
      "Read(config/schema/**)",
      "Read(config/example/**)",
      "Read(config/dev/**)",

      "Read(*.md)",
      "Read(src/**)",

      "Write(src/**)",
      "Edit(src/**)",

      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",

      "Bash(pnpm run dev)",
      "Bash(pnpm test *)"
    ],

    "ask": ["Bash(git push *)"],

    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",

      "Read(config/prod/**)",
      "Read(config/secrets/**)",
      "Read(secrets/**)",

      "Read(*secret*)",
      "Read(*password*)",

      "Bash(*.env*)",
      "Bash(cat *.env*)",
      "Bash(grep *.env*)",
      "Bash(printenv*)",

      "Bash(curl *)",
      "Bash(wget *)",

      "Bash(rm -rf *)",
      "Bash(git reset *)",
      "Bash(git clean *)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/notifications/notify.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Claude Code is about to read a file. Please review the file content and ensure it does not contain sensitive information.'"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/pre-commit.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/hook-input-output.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Claude Code has finished reading a file. Please review the file content that was read to ensure it does not contain sensitive information.'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Claude Code has a new notification. Please review the notification content to ensure it does not contain sensitive information.'"
          }
        ]
      }
    ]
  },
  "env": {
    "DISABLE_TELEMETRY": "1",
    "autoMemoryEnabled": "true",
    "autoMemoryDirectory": "./my-custom-memory-dir"
  },
  "showTurnDuration": true
}
